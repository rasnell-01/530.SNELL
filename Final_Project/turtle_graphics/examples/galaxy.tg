# galaxy.tg
#
# Five spiral arms arranged symmetrically, like a galaxy.
# Each arm is drawn by a procedure that uses a growing step variable.
#
# Demonstrates:
#   - procedure called inside dotimes
#   - variables shared between the main program and the procedure body

to arm {
    set step 4
    dotimes 30 {
        forward step
        turn 12
        set step (step + 1.5)
    }
}

pen 1
dotimes 5 {
    arm
    turn 72
}
